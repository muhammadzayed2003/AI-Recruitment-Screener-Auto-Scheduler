    {
      "parameters": {
        "jsCode": "const text = $input.first().json.output;\n\n// Try multiple patterns to catch different score formats\nlet score = 0;\n\n// Pattern 1: \"88/100\" format (bold or plain)\nlet match = text.match(/\\*{0,2}(\\d{1,3})\\s*\\/\\s*100\\*{0,2}/);\nif (match) {\n  score = parseInt(match[1]);\n} else {\n  // Pattern 2: \"Score: 88\" or \"Score of 88\" or \"scored 88\"\n  match = text.match(/score[d:\\s\\-of]*\\**\\s*(\\d{1,3})/i);\n  if (match) score = parseInt(match[1]);\n}\n\nconst nameMatch = text.match(/\\*\\*([A-Za-z\\s]+)\\*\\*/);\nconst applicantName = nameMatch ? nameMatch[1].trim() : \"Applicant\";\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    score: score,\n    applicantName: applicantName\n  }\n}];"
      },
