    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an email classifier. Analyze the following email and determine if it \nis a JOB APPLICATION or NOT.\n\nEmail Subject: {{ $json.subject }}\nEmail Body/Snippet: {{ $json.snippet }}\n\nA job application typically includes: mentions of applying for a position, \nwords like \"application\", \"resume\", \"CV\", \"job\", \"position\", \"hiring\", \n\"applying\", or similar intent related to employment.\n\nRespond with ONLY one word: \"YES\" if it's a job application, or \"NO\" if it's \nnot (e.g., spam, newsletter, unrelated business email, promotional content).\n\nDo not include any explanation, punctuation, or additional text — respond with \nexactly \"YES\" or \"NO\".",
        "batching": {}
